  id: analog_agc3_xx
  parameters:
    affinity: ''
    alias: ''
    attack_rate: pow(10, agc_attack)
    comment: "Set attack/decay, so it doesn't \nslope the peaks during a packet,\n\
      but high enough so it's fast enough\nto keep the packet peaks at around 1"
    decay_rate: pow(10, agc_decay)
    gain: '1.0'
    iir_update_decim: '1'
    max_gain: '100'
    maxoutbuf: '0'
    minoutbuf: '0'
    reference: '2'
    type: complex
  states:
