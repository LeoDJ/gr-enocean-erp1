- name: erp1
  id: epy_module
  parameters:
    alias: ''
    comment: EnOcean Radio Protocol 1 util
    source_code: "# this module will be imported in the into your flowgraph\r\nimport\
      \ traceback\r\nimport numpy as np\r\n\r\npolynomial = 0x07\r\n\r\ndef crc8(data:\
      \ bytes) -> int:\r\n    crc = 0x00\r\n\r\n    for byte in data:\r\n        crc\
      \ ^= byte\r\n\r\n        for _ in range(8):\r\n            if crc & 0x80:\r\n\
      \                crc = (((crc << 1) & 0xFF) ^ polynomial)\r\n            else:\r\
      \n                crc = (crc << 1) & 0xFF\r\n\r\n    return crc\r\n\r\ndef checksum(data:\
      \ bytes) -> int:\r\n    sum = 0\r\n    for byte in data:\r\n        sum += (byte)\r\
      \n        sum &= 0xFF\r\n    return sum\r\n\r\ndef decode12to8(bit_list):\r\n\
      \    try:\r\n        out_list = []\r\n        err = False\r\n        eof = None\r\
      \n        b = 0\r\n\r\n        for i, bit in enumerate(bit_list):\r\n      \
      \      bit_pos = i % 12\r\n            byte_pos = i//12\r\n            \r\n\
      \            if bit_pos <= 2:\r\n                b |= bit << (7 - bit_pos)\r\
      \n            elif bit_pos == 3:\r\n                if bit == (b>>5 & 1):\r\n\
      \                    err = bit_pos\r\n            elif bit_pos <= 6:\r\n   \
      \             b |= bit << (7 - bit_pos + 1)\r\n            elif bit_pos == 7:\r\
      \n                if bit == (b>>2 & 1):\r\n                    err = bit_pos\r\
      \n            elif bit_pos <= 9:\r\n                b |= bit << (7 - bit_pos\
      \ + 2)\r\n            elif bit_pos == 10:\r\n                eof = bit\r\n \
      \           elif bit_pos == 11:\r\n                if bit == eof:\r\n      \
      \              err = bit_pos\r\n\r\n                decoded_byte = ~b & 0xFF\r\
      \n                out_list.append(decoded_byte) # invert bits\r\n          \
      \      b = 0\r\n\r\n                if not eof: # last byte reached (inverted)\r\
      \n                    status_byte, checksum_byte = out_list[-2:]\r\n       \
      \             if status_byte & 0x80:  # CRC8 algorithm\r\n                 \
      \       crc_checksum = crc8(out_list[:-1])\r\n                        # print(f\"\
      Status: {status_byte:02X}, CheckByte: {checksum_byte:02X}, ChecksumCalc: {crc_checksum:02X}\"\
      )\r\n                        if crc_checksum != checksum_byte:\r\n         \
      \                   err = 12\r\n                            # break\r\n    \
      \                else:                   # Sum algorithm\r\n               \
      \         sum = checksum(out_list[:-1])\r\n                        # print(f\"\
      Status: {status_byte:02X}, CheckByte: {checksum_byte:02X}, ChecksumCalc: {sum:02X}\"\
      )\r\n                        if sum != checksum_byte:\r\n                  \
      \          err = 12\r\n                            # break\r\n             \
      \       break\r\n\r\n        \r\n\r\n        print(' '.join(f'{int(x):02X}'\
      \ for x in out_list) + (f\" Error {err}!\" if err else \"\") + (\" (Checksum)\"\
      \ if err == 12 else \"\"))\r\n        if err:\r\n            out_list = []\r\
      \n        return np.array(out_list)\r\n    except Exception:\r\n        traceback.print_exc()"
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [680, 1264.0]
    rotation: 0
    state: enabled
