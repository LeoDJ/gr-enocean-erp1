options:
  parameters:
    author: LeoDJ
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: ''
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: enocean_erp1
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: EnOcean Receiver
    window_size: (1000,1000)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [16, 12.0]
    rotation: 0
    state: enabled

blocks:
- name: a_bit_file_name
  id: variable
  parameters:
    comment: ''
    value: f'recording/data_{time.strftime("%Y-%m-%dT%H-%M-%S")}.bin' if write_decoded_bits
      else "recording/dummy.bin"
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1600, 1252.0]
    rotation: 0
    state: enabled
- name: a_iq_file_name
  id: variable
  parameters:
    comment: needs to start with a, otherwise other variables are not defined?
    value: f'recording/raw_{time.strftime("%Y-%m-%dT%H-%M-%S")}_{self.freq/1e6}MHz_{self.samp_rate/1e6}MSps.iq'
      if write_raw_iq else "recording/dummy.iq"
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [280, 796.0]
    rotation: 0
    state: enabled
- name: agc_attack
  id: variable_qtgui_range
